# ============================================================
# .gitignore — Social Travel Booking
# ============================================================

# ── Laravel Backend ─────────────────────────────────────────
backend/.env
backend/vendor/
backend/node_modules/
backend/storage/logs/
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/
backend/bootstrap/cache/
backend/firebase-service-account.json   # ⚠️ KHÔNG commit file này
backend/firebase-debug.log

# ── React Frontend ──────────────────────────────────────────
frontend_web/node_modules/
frontend_web/dist/
frontend_web/.env
frontend_web/.env.local
frontend_web/.env.production

# ── Flutter Mobile ──────────────────────────────────────────
mobile_app/.dart_tool/
mobile_app/build/
mobile_app/.flutter-plugins
mobile_app/.flutter-plugins-dependencies
mobile_app/.env
mobile_app/android/local.properties
mobile_app/android/key.properties
mobile_app/ios/Pods/
mobile_app/ios/.symlinks/

# ── Docker ──────────────────────────────────────────────────
.env                        # file .env gốc ở root (docker-compose dùng)

# ── Editor & OS ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.log
.DS_Store
Thumbs.db
desktop.ini