      ],
      "id": "api-bulk-process"
    },
    {
      "parameters": {
        "triggerTimes": {
          "item": [
            {
              "mode": "everyDay",
              "hour": 3
            }
          ]
        }
      },
      "name": "Cron: Daily Cleanup",
